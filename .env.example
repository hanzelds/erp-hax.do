# ============================================
# ERP HAX — Variables de Entorno
# Copiar este archivo como .env en cada app
# ============================================

# --- BASE DE DATOS ---
DATABASE_URL="postgresql://hax_user:hax_password@localhost:5432/erp_hax"

# --- REDIS ---
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_SECRET="CAMBIAR_POR_SECRET_SEGURO_256_BITS"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET="CAMBIAR_POR_REFRESH_SECRET_SEGURO"
JWT_REFRESH_EXPIRES_IN="7d"

# --- API ---
API_PORT=4000
API_URL="http://localhost:4000"
NODE_ENV="development"

# --- FRONTEND ---
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_APP_NAME="ERP Hax"
NEXT_PUBLIC_APP_URL="https://erp.hax.com.do"

# --- ALANUBE ---
ALANUBE_API_URL="https://api.alanube.com.do"
ALANUBE_API_KEY="TU_API_KEY_ALANUBE"
ALANUBE_ENV="sandbox"   # sandbox | production

# --- EMPRESA ---
COMPANY_NAME="HAX ESTUDIO CREATIVO EIRL"
COMPANY_RNC="133290251"
COMPANY_EMAIL="info@hax.com.do"
COMPANY_PHONE="8297743955"

# --- EMAIL (para comprobantes de nómina) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="info@hax.com.do"
SMTP_PASS="TU_APP_PASSWORD"

