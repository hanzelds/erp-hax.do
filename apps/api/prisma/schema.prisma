generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id @default(cuid())
  name                  String
  email                 String               @unique
  password              String
  role                  UserRole             @default(ACCOUNTANT)
  isActive              Boolean              @default(true)
  lastLogin             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  approvals             ApprovalRequest[]    @relation("ApprovedBy")
  approvalRequests      ApprovalRequest[]    @relation("RequestedBy")
  auditLogs             AuditLog[]
  closedReconciliations BankReconciliation[] @relation("ReconciliationClosedBy")
  createdInvoices       Invoice[]            @relation("InvoiceCreatedBy")

  @@index([email])
  @@index([role, isActive])
  @@map("users")
}

model Client {
  id               String           @id @default(cuid())
  name             String
  businessName     String?
  rnc              String?          @unique
  cedula           String?          @unique
  email            String?
  phone            String?
  address          String?
  city             String?
  notes            String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  crmOpportunities CrmOpportunity[]
  invoices         Invoice[]
  quotes           Quote[]

  @@index([name])
  @@index([isActive])
  @@map("clients")
}

model CrmOpportunity {
  id           String       @id @default(cuid())
  clientId     String
  businessUnit BusinessUnit
  title        String
  description  String?
  value        Float?
  status       LeadStatus   @default(LEAD)
  probability  Int          @default(0)
  expectedDate DateTime?
  closedAt     DateTime?
  closedReason String?
  assignedTo   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  client       Client       @relation(fields: [clientId], references: [id])
  quotes       Quote[]

  @@index([clientId])
  @@index([status])
  @@index([businessUnit])
  @@map("crm_opportunities")
}

model Quote {
  id                 String          @id @default(cuid())
  number             String          @unique
  clientId           String
  opportunityId      String?
  businessUnit       BusinessUnit
  status             QuoteStatus     @default(DRAFT)
  validUntil         DateTime?
  notes              String?
  terms              String?
  subtotal           Float           @default(0)
  taxAmount          Float           @default(0)
  total              Float           @default(0)
  convertedInvoiceId String?         @unique
  convertedAt        DateTime?
  sentAt             DateTime?
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  invoice            Invoice?        @relation("QuoteInvoice")
  items              QuoteItem[]
  client             Client          @relation(fields: [clientId], references: [id])
  opportunity        CrmOpportunity? @relation(fields: [opportunityId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([businessUnit])
  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float   @default(0.18)
  taxAmount   Float   @default(0)
  subtotal    Float
  total       Float
  isExempt    Boolean @default(false)
  sortOrder   Int     @default(0)
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

model Invoice {
  id                String           @id @default(cuid())
  number            String           @unique
  clientId          String
  businessUnit      BusinessUnit
  type              InvoiceType      @default(CREDITO_FISCAL)
  status            InvoiceStatus    @default(DRAFT)
  paymentStatus     PaymentStatus    @default(PENDING)
  issueDate         DateTime         @default(now())
  dueDate           DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  paidAt            DateTime?
  cancelledAt       DateTime?
  subtotal          Float            @default(0)
  taxAmount         Float            @default(0)
  total             Float            @default(0)
  amountPaid        Float            @default(0)
  amountDue         Float            @default(0)
  notes             String?
  ncf               String?
  xml               String?
  alanubeId         String?
  alanubeStatus     String?
  rejectionReason   String?
  originalInvoiceId String?
  fromQuoteId       String?          @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  retryCount        Int              @default(0)
  sentAt            DateTime?
  pdfPath           String?
  pdfGeneratedAt    DateTime?
  pdfStatus         PdfStatus        @default(NONE)
  createdById       String?
  alanubeRequests   AlanubeRequest[]
  items             InvoiceItem[]
  client            Client           @relation(fields: [clientId], references: [id])
  createdBy         User?            @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  fromQuote         Quote?           @relation("QuoteInvoice", fields: [fromQuoteId], references: [convertedInvoiceId])
  originalInvoice   Invoice?         @relation("CreditNoteRef", fields: [originalInvoiceId], references: [id])
  creditNotes       Invoice[]        @relation("CreditNoteRef")
  journalEntries    JournalEntry[]
  payments          Payment[]

  @@index([clientId])
  @@index([status])
  @@index([paymentStatus])
  @@index([businessUnit])
  @@index([ncf])
  @@index([issueDate])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float   @default(0.18)
  taxAmount   Float   @default(0)
  subtotal    Float
  total       Float
  isExempt    Boolean @default(false)
  sortOrder   Int     @default(0)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model AlanubeRequest {
  id              String    @id @default(cuid())
  invoiceId       String
  attempt         Int       @default(1)
  requestPayload  Json
  sentAt          DateTime  @default(now())
  status          String?
  responsePayload Json?
  ncf             String?
  xml             String?
  errorCode       String?
  errorMessage    String?
  receivedAt      DateTime?
  invoice         Invoice   @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([status])
  @@map("alanube_requests")
}

model Payment {
  id               String            @id @default(cuid())
  invoiceId        String
  amount           Float
  method           PaymentMethod     @default(TRANSFER)
  reference        String?
  notes            String?
  paidAt           DateTime          @default(now())
  isReversed       Boolean           @default(false)
  reversedAt       DateTime?
  createdAt        DateTime          @default(now())
  journalEntries   JournalEntry[]
  invoice          Invoice           @relation(fields: [invoiceId], references: [id])
  bankTransactions BankTransaction[] @relation("PaymentBankTx")

  @@index([invoiceId])
  @@index([paidAt])
  @@map("payments")
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  businessName   String?
  rnc            String?         @unique
  email          String?
  phone          String?
  address        String?
  city           String?
  category       ExpenseCategory @default(OPERATIONS)
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  expenses       Expense[]
  fixedAssets    FixedAsset[]
  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@index([isActive])
  @@map("suppliers")
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  products    Product[]

  @@map("product_categories")
}

model Product {
  id           String           @id @default(cuid())
  businessUnit BusinessUnit
  code         String?          @unique
  name         String
  description  String?
  categoryId   String?
  type         String           @default("SERVICE")
  unitPrice    Float            @default(0)
  taxRate      Float            @default(0.18)
  isExempt     Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  category     ProductCategory? @relation(fields: [categoryId], references: [id])

  @@index([businessUnit])
  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

model Expense {
  id             String          @id @default(cuid())
  businessUnit   BusinessUnit
  supplierId     String?
  supplier       String
  description    String
  amount         Float
  taxAmount      Float           @default(0)
  total          Float
  category       ExpenseCategory @default(OPERATIONS)
  ncf            String?
  receiptUrl     String?
  status         ExpenseStatus   @default(DRAFT)
  approvedAt     DateTime?
  paidAt         DateTime?
  expenseDate    DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  supplierRef    Supplier?       @relation(fields: [supplierId], references: [id])
  journalEntries JournalEntry[]

  @@index([businessUnit])
  @@index([category])
  @@index([expenseDate])
  @@index([status])
  @@index([supplierId])
  @@map("expenses")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  number       String              @unique
  businessUnit BusinessUnit
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  notes        String?
  subtotal     Float               @default(0)
  taxAmount    Float               @default(0)
  total        Float               @default(0)
  sentAt       DateTime?
  confirmedAt  DateTime?
  receivedAt   DateTime?
  cancelledAt  DateTime?
  expenseId    String?             @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  items        PurchaseOrderItem[]
  supplier     Supplier            @relation(fields: [supplierId], references: [id])

  @@index([businessUnit])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  description     String
  quantity        Float
  unitPrice       Float
  taxRate         Float         @default(0.18)
  taxAmount       Float         @default(0)
  subtotal        Float
  total           Float
  sortOrder       Int           @default(0)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model RecurringPayment {
  id           String             @id @default(cuid())
  businessUnit BusinessUnit
  name         String
  description  String?
  supplierId   String?
  supplier     String
  amount       Float
  category     ExpenseCategory    @default(OPERATIONS)
  frequency    RecurringFrequency @default(MONTHLY)
  nextDueDate  DateTime
  lastPaidAt   DateTime?
  isActive     Boolean            @default(true)
  autoGenerate Boolean            @default(true)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([businessUnit])
  @@index([nextDueDate])
  @@index([isActive])
  @@map("recurring_payments")
}

model Account {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  type          AccountType
  parentId      String?
  isActive      Boolean        @default(true)
  allowsEntry   Boolean        @default(true)
  description   String?
  createdAt     DateTime       @default(now())
  parent        Account?       @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[]      @relation("AccountHierarchy")
  creditEntries JournalEntry[] @relation("CreditAccount")
  debitEntries  JournalEntry[] @relation("DebitAccount")

  @@index([code])
  @@index([isActive])
  @@index([type])
  @@index([parentId])
  @@map("accounts")
}

model JournalEntry {
  id                String             @id @default(cuid())
  type              JournalEntryType
  businessUnit      BusinessUnit
  description       String
  debitAccountId    String
  creditAccountId   String
  amount            Float
  period            String
  entryDate         DateTime           @default(now())
  isReversed        Boolean            @default(false)
  reversedAt        DateTime?
  createdAt         DateTime           @default(now())
  invoiceId         String?
  paymentId         String?
  expenseId         String?
  payrollId         String?
  depreciationEntry DepreciationEntry?
  creditAccount     Account            @relation("CreditAccount", fields: [creditAccountId], references: [id])
  debitAccount      Account            @relation("DebitAccount", fields: [debitAccountId], references: [id])
  expense           Expense?           @relation(fields: [expenseId], references: [id])
  invoice           Invoice?           @relation(fields: [invoiceId], references: [id])
  payment           Payment?           @relation(fields: [paymentId], references: [id])
  payroll           Payroll?           @relation(fields: [payrollId], references: [id])

  @@index([businessUnit])
  @@index([period])
  @@index([type])
  @@index([entryDate])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([expenseId])
  @@map("journal_entries")
}

model BankAccount {
  id              String               @id @default(cuid())
  businessUnit    BusinessUnit?
  name            String
  bank            String
  accountNumber   String?
  type            String               @default("CHECKING")
  currency        String               @default("DOP")
  balance         Float                @default(0)
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  reconciliations BankReconciliation[]
  transactions    BankTransaction[]

  @@index([businessUnit])
  @@index([isActive])
  @@map("bank_accounts")
}

model BankTransaction {
  id              String                @id @default(cuid())
  bankAccountId   String
  type            BankTransactionType   @default(CREDIT)
  amount          Float
  balance         Float                 @default(0)
  description     String
  reference       String?
  transactionDate DateTime
  status          BankTransactionStatus @default(UNMATCHED)
  matchedAt       DateTime?
  createdAt       DateTime              @default(now())
  bankAccount     BankAccount           @relation(fields: [bankAccountId], references: [id])
  payments        Payment[]             @relation("PaymentBankTx")

  @@index([bankAccountId])
  @@index([status])
  @@index([transactionDate])
  @@map("bank_transactions")
}

model Employee {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  phone        String?
  cedula       String?       @unique
  type         EmployeeType  @default(SALARIED)
  businessUnit BusinessUnit
  position     String?
  baseSalary   Float
  isActive     Boolean       @default(true)
  hiredAt      DateTime      @default(now())
  terminatedAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  payrollItems PayrollItem[]

  @@index([businessUnit])
  @@index([type, isActive])
  @@map("employees")
}

model Payroll {
  id                   String         @id @default(cuid())
  businessUnit         BusinessUnit
  period               String
  status               PayrollStatus  @default(CALCULATED)
  totalGross           Float
  totalAfpEmployee     Float          @default(0)
  totalAfpEmployer     Float          @default(0)
  totalSfsEmployee     Float          @default(0)
  totalSfsEmployer     Float          @default(0)
  totalIsr             Float          @default(0)
  totalOtherDeductions Float          @default(0)
  totalNet             Float
  totalEmployerCost    Float          @default(0)
  approvedAt           DateTime?
  paidAt               DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  journalEntries       JournalEntry[]
  items                PayrollItem[]

  @@unique([businessUnit, period])
  @@index([status])
  @@index([period])
  @@map("payrolls")
}

model PayrollItem {
  id               String    @id @default(cuid())
  payrollId        String
  employeeId       String
  grossSalary      Float
  afpEmployee      Float     @default(0)
  sfsEmployee      Float     @default(0)
  isr              Float     @default(0)
  otherDeductions  Float     @default(0)
  netSalary        Float
  afpEmployer      Float     @default(0)
  sfsEmployer      Float     @default(0)
  sfsRiesgoLaboral Float     @default(0)
  emailSent        Boolean   @default(false)
  emailSentAt      DateTime?
  pdfPath          String?
  pdfGeneratedAt   DateTime?
  pdfStatus        PdfStatus @default(NONE)
  employee         Employee  @relation(fields: [employeeId], references: [id])
  payroll          Payroll   @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@unique([payrollId, employeeId])
  @@index([payrollId])
  @@map("payroll_items")
}

model FiscalReport {
  id           String           @id @default(cuid())
  type         FiscalReportType
  period       String
  businessUnit BusinessUnit
  recordCount  Int              @default(0)
  totalAmount  Float            @default(0)
  totalItbis   Float            @default(0)
  generatedAt  DateTime         @default(now())
  fileUrl      String?

  @@unique([type, period, businessUnit])
  @@index([period])
  @@map("fiscal_reports")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String
  action    AuditAction
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ApprovalRequest {
  id              String         @id @default(cuid())
  entity          String
  entityId        String
  changeRequested Json
  reason          String?
  status          ApprovalStatus @default(PENDING)
  requestedById   String
  approvedById    String?
  adminNotes      String?
  resolvedAt      DateTime?
  createdAt       DateTime       @default(now())
  approvedBy      User?          @relation("ApprovedBy", fields: [approvedById], references: [id])
  requestedBy     User           @relation("RequestedBy", fields: [requestedById], references: [id])

  @@index([entity, entityId])
  @@index([status])
  @@map("approval_requests")
}

model FiscalPeriod {
  id        String    @id @default(cuid())
  period    String    @unique
  isClosed  Boolean   @default(false)
  closedAt  DateTime?
  closedBy  String?
  notes     String?
  createdAt DateTime  @default(now())

  @@index([isClosed])
  @@map("fiscal_periods")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model CompanyConfig {
  id          String   @id @default("main")
  companyName String   @default("HAX ESTUDIO CREATIVO EIRL")
  rnc         String   @default("133290251")
  address     String?
  phone       String?
  email       String?
  logoUrl     String?
  website     String?
  // SMTP email settings
  smtpEnabled Boolean  @default(false)
  smtpHost    String?
  smtpPort    Int      @default(587)
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  smtpSsl     Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@map("company_config")
}

model FixedAsset {
  id                      String              @id @default(cuid())
  name                    String
  category                FixedAssetCategory
  businessUnit            BusinessUnit
  purchaseDate            DateTime
  purchaseValue           Float
  usefulLifeMonths        Int
  salvageValue            Float               @default(0)
  accumulatedDepreciation Float               @default(0)
  bookValue               Float
  status                  FixedAssetStatus    @default(ACTIVE)
  supplierId              String?
  ncfCompra               String?
  notes                   String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  depreciationEntries     DepreciationEntry[]
  supplier                Supplier?           @relation(fields: [supplierId], references: [id])

  @@index([businessUnit])
  @@index([status])
  @@map("fixed_assets")
}

model DepreciationEntry {
  id             String        @id @default(cuid())
  assetId        String
  period         String
  amount         Float
  journalEntryId String?       @unique
  createdAt      DateTime      @default(now())
  asset          FixedAsset    @relation(fields: [assetId], references: [id])
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@unique([assetId, period])
  @@index([assetId])
  @@index([period])
  @@map("depreciation_entries")
}

model Budget {
  id             String       @id @default(cuid())
  businessUnit   BusinessUnit
  period         String
  category       String       @default("TOTAL")
  amountBudgeted Float
  amountExecuted Float        @default(0)
  status         BudgetStatus @default(ON_TRACK)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([businessUnit, period, category])
  @@index([businessUnit])
  @@index([period])
  @@map("budgets")
}

model BankReconciliation {
  id            String               @id @default(cuid())
  period        String
  bankAccountId String
  status        ReconciliationStatus @default(OPEN)
  closedById    String?
  closedAt      DateTime?
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  bankAccount   BankAccount          @relation(fields: [bankAccountId], references: [id])
  closedBy      User?                @relation("ReconciliationClosedBy", fields: [closedById], references: [id])
  transactions  ReconciliationTx[]

  @@unique([period, bankAccountId])
  @@index([status])
  @@map("bank_reconciliations")
}

model ReconciliationTx {
  id               String             @id @default(cuid())
  reconciliationId String
  txDate           DateTime
  description      String
  amount           Float
  reference        String?
  status           String             @default("UNMATCHED")
  matchedPaymentId String?
  matchedExpenseId String?
  notes            String?
  createdAt        DateTime           @default(now())
  reconciliation   BankReconciliation @relation(fields: [reconciliationId], references: [id])

  @@index([reconciliationId])
  @@index([status])
  @@map("reconciliation_txs")
}

model EcfConfig {
  id                  String   @id @default("main")
  alanubeEnabled      Boolean  @default(false)
  alanubeApiKey       String?
  alanubeEnv          String   @default("sandbox")
  alanubeApiUrl       String   @default("https://api.alanube.com.do")
  ncfCreditoFiscal    Int      @default(1)
  ncfConsumidor       Int      @default(1)
  ncfNotaDebito       Int      @default(1)
  ncfNotaCredito      Int      @default(1)
  ncfCompras          Int      @default(1)
  ncfRegimen          Int      @default(1)
  itbisRate           Float    @default(0.18)
  maxRetroactiveDays  Int      @default(5)
  maxRetryCount       Int      @default(5)
  autoJournalEntries  Boolean  @default(true)
  requireRncB01       Boolean  @default(true)
  pollIntervalSeconds Int      @default(3)
  pollTimeoutMinutes  Int      @default(5)
  // Invoice settings
  invoiceDueDays       Int    @default(30)
  defaultPaymentMethod String @default("TRANSFER")
  // Budget settings
  budgetAlertThreshold    Float @default(0.8)
  budgetExceededThreshold Float @default(1.0)
  // Fixed asset settings
  fixedAssetThreshold Float @default(10000)
  // Payroll / TSS rates (Dominican Republic)
  payrollAfpEmployee   Float @default(0.0287)
  payrollAfpEmployer   Float @default(0.0710)
  payrollSfsEmployee   Float @default(0.0304)
  payrollSfsEmployer   Float @default(0.0709)
  payrollRiesgoLaboral Float @default(0.0120)
  // Accounting account codes
  acctCash              String @default("1101")
  acctBank              String @default("1102")
  acctReceivables       String @default("1201")
  acctItbisReceivable   String @default("1302")
  acctPayablesSuppliers String @default("2101")
  acctPayablesEmployees String @default("2102")
  acctPayablesTss       String @default("2103")
  acctPayablesIsr       String @default("2104")
  acctItbisPayable      String @default("2201")
  acctIncomeHax         String @default("4101")
  acctIncomeKoder       String @default("4102")
  acctExpenseGeneral    String @default("5101")
  acctExpenseSalaries   String @default("5102")
  acctExpenseMarketing  String @default("5103")
  updatedAt             DateTime @updatedAt

  @@map("ecf_config")
}

model ITBISPeriod {
  id                    String      @id @default(cuid())
  period                String      @unique   // "202501"
  year                  Int
  month                 Int
  startDate             DateTime
  endDate               DateTime
  dueDate               DateTime
  status                ITBISStatus @default(OPEN)
  totalSalesItbis       Float       @default(0)
  totalPurchasesItbis   Float       @default(0)
  deductibleItbis       Float       @default(0)
  payableItbis          Float       @default(0)
  carryForwardBalance   Float       @default(0)
  prevCarryForward      Float       @default(0)
  declaredAt            DateTime?
  paidAt                DateTime?
  notes                 String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([status])
  @@index([year])
